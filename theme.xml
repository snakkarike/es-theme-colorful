<theme>
    <formatVersion>7</formatVersion>
    <variables>
        <helpIconColor>ffffff99</helpIconColor>
        <helpTextColor>ffffff99</helpTextColor>
        <helpBackgroundColor>00000022</helpBackgroundColor>
        <systemLabelColor>ffffffaa</systemLabelColor>
        <systemNameColor>ffffff</systemNameColor>
        <systemDescriptionColor>ffffff</systemDescriptionColor>
        <systemGameCountColor>ffffff99</systemGameCountColor>
        <gamelistSelectorColor>00000033</gamelistSelectorColor>
        <gamelistPrimaryColor>ffffff66</gamelistPrimaryColor>
        <gamelistSecondaryColor>ffffff66</gamelistSecondaryColor>
        <gamelistSelectedColor>ffffff</gamelistSelectedColor>
        <gameDescription>ffffff</gameDescription>
        <gameMetadataLabel>ffffffaa</gameMetadataLabel>
        <gameMetadata>ffffff</gameMetadata>
        <!-- Fixed: was pointing to non-existent _inc/ directory -->
        <gameMetadataBackground>./_art/assets/metadata-background-dark.svg</gameMetadataBackground>
        <batteryIndicatorColor>ffffff99</batteryIndicatorColor>
    </variables>

    <!-- ═══════════════════════════════════════════════════════
         COLOR SCHEME SUBSET
         Selectable via Main Menu → UI Settings → Theme Color Scheme
         ═══════════════════════════════════════════════════════ -->
    <subset name="color-scheme" displayName="Theme Color Scheme">
        <!-- Default: per-system accent colours from each system folder -->
        <include name="colorful"      displayName="Colorful" />
        <include name="dark"          displayName="Dark" />
        <include name="oled"          displayName="OLED" />
        <include name="light"         displayName="Light" />
        <include name="retro-bright"  displayName="RetroBright" />
        <include name="dmg"           displayName="DMG" />
    </subset>

    <!-- Color scheme includes — loaded when user selects a scheme -->
    <include subset="color-scheme" name="dark">./dark.xml</include>
    <include subset="color-scheme" name="oled">./oled.xml</include>
    <include subset="color-scheme" name="light">./light.xml</include>
    <include subset="color-scheme" name="retro-bright">./retro-bright.xml</include>
    <include subset="color-scheme" name="dmg">./dmg.xml</include>

    <!-- ═══════════════════════════════════════════════════════
         VARIANT SUBSET
         Selectable via Main Menu → UI Settings → Theme Variant
         ═══════════════════════════════════════════════════════ -->
    <subset name="variant" displayName="Theme Variant">
        <include name="list-boxart"              displayName="List: Boxart" />
        <include name="list-screenshot"          displayName="List: Screenshot" />
        <include name="list-screenshot-marquee"  displayName="List: Screenshot + Marquee" />
        <include name="list-metadata-screenshot" displayName="List: Metadata &amp; Screenshot" />
    </subset>

    <!-- Variant includes — loaded when user selects a layout -->
    <include subset="variant" name="list-boxart">./variant-boxart.xml</include>
    <include subset="variant" name="list-screenshot">./variant-screenshot.xml</include>
    <include subset="variant" name="list-screenshot-marquee">./variant-screenshot-marquee.xml</include>
    <include subset="variant" name="list-metadata-screenshot">./variant-metadata-screenshot.xml</include>

    <variables>
        <spacerImage>./_art/assets/space.png</spacerImage>
        <fontLight>./_art/Gilroy-Light.ttf</fontLight>
        <fontRegular>./_art/Gilroy-Regular.ttf</fontRegular>
        <!-- Fixed: was self-referencing (${fontSemiBold}), now points to actual file -->
        <fontSemiBold>./_art/Gilroy-SemiBold.ttf</fontSemiBold>
        <fontBold>./_art/Gilroy-Bold.ttf</fontBold>
        <fontHelpSystem>./_art/Akrobat-Bold.ttf</fontHelpSystem>
        <menuFontBold>./_art/Oxygen-Bold.ttf</menuFontBold>
        <menuFontLight>./_art/Oxygen-Light.ttf</menuFontLight>
        <menuFontRegular>./_art/Oxygen-Regular.ttf</menuFontRegular>
    </variables>

    <view name="system">

        <image name="background" extra="true">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${systemBackgroundColor}</color>
            <zIndex>0</zIndex>
        </image>

        <image name="backgroundhelp" extra="true">
            <origin>0 1</origin>
            <pos>0 1</pos>
            <size>1 0.075</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${helpBackgroundColor}</color>
            <zIndex>0</zIndex>
        </image>

        <helpsystem name="help">
            <textColor>${helpTextColor}</textColor>
            <iconColor>${helpIconColor}</iconColor>
            <fontPath>${menuFontBold}</fontPath>
            <!-- Reverted to 0.0225: 0.028 caused overflow with 4-5 items on 640px bar -->
            <fontSize>0.0225</fontSize>
            <pos>0.025 0.975</pos>
            <origin>0 1</origin>
            <iconUpDown>./_art/assets/help-dpad-updown.svg</iconUpDown>
            <iconLeftRight>./_art/assets/help-dpad-leftright.svg</iconLeftRight>
            <iconUpDownLeftRight>./_art/assets/help-dpad-updownleftright.svg</iconUpDownLeftRight>
            <iconA>./_art/assets/help-button-east.svg</iconA>
            <iconB>./_art/assets/help-button-south.svg</iconB>
            <iconX>./_art/assets/help-button-north.svg</iconX>
            <iconY>./_art/assets/help-button-west.svg</iconY>
        </helpsystem>

        <sound name="bgsound">
            <!-- try mp3 -->
            <path>./_art/assets/sounds/${system.theme}.mp3</path>
            <!-- try ogg -->
            <path>./_art/assets/sounds/${system.theme}.ogg</path>

        </sound>

        <image name="poster" extra="true">
            <path>./_art/systems/${system.theme}.webp</path>
            <tile>false</tile>
            <origin>1 0</origin>
            <pos>1 0.125</pos>
            <size>0 0.75</size>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </image>

        <carousel name="systemcarousel">
            <type>vertical</type>
            <color>00000000</color>
            <origin>1 1</origin>
            <pos>1 1</pos>
            <size>0.01 0.01</size>
            <logoScale>1</logoScale>
            <logoSize>0.01 0.01</logoSize>
            <maxLogoCount>0</maxLogoCount>
        </carousel>

        <text name="sys_line1" extra="true">
            <fontPath>${fontBold}</fontPath>
            <alignment>left</alignment>
            <forceUppercase>0</forceUppercase>
            <fontSize>0.05</fontSize>
            <origin>0 0</origin>
            <pos>0.025 0.125</pos>
            <size>0 0</size>
            <color>${systemNameColor}</color>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>

        <text name="shortdescription" extra="true">
            <fontPath>${fontBold}</fontPath>
            <alignment>left</alignment>
            <forceUppercase>0</forceUppercase>
            <fontSize>0.025</fontSize>
            <color>${systemLabelColor}</color>
            <origin>0 0</origin>
            <pos>0.025 0.1</pos>
            <size>0.5 0.025</size>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>

        <text name="systemInfo">
            <fontPath>${fontBold}</fontPath>
            <alignment>left</alignment>
            <backgroundColor>00000000</backgroundColor>
            <forceUppercase>1</forceUppercase>
            <color>${systemGameCountColor}</color>
            <origin>0 0</origin>
            <pos>0.025 0.220</pos>
            <size>0.400 0.045</size>
            <fontSize>0.04</fontSize>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>

        <text name="longdescription" extra="true">
            <fontPath>${fontRegular}</fontPath>
            <alignment>left</alignment>
            <forceUppercase>0</forceUppercase>
            <fontSize>0.03</fontSize>
            <color>${systemDescriptionColor}</color>
            <lineSpacing>1.18</lineSpacing>
            <origin>0 0</origin>
            <!-- Fixed: was 0.7 with size 0.5→ bled into help bar; capped at 0.85 -->
            <pos>0.025 0.28</pos>
            <size>0.5 0.57</size>
            <container>true</container>
            <verticalAlignment>top</verticalAlignment>
            <zIndex>5</zIndex>
            <autoScroll>vertical</autoScroll>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>

    </view>

    <view name="basic, detailed, video">

        <image name="background" extra="true">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${systemBackgroundColor}</color>
            <zIndex>0</zIndex>
        </image>
        <image name="backgroundhelp" extra="true">
            <origin>0 1</origin>
            <pos>0 1</pos>
            <size>1 0.075</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${helpBackgroundColor}</color>
            <zIndex>0</zIndex>
        </image>

        <textlist name="gamelist">
            <selectorColor>${gamelistSelectorColor}</selectorColor>
            <selectedColor>${gamelistSelectedColor}</selectedColor>
            <selectorHeight>0.06</selectorHeight>
            <primaryColor>${gamelistPrimaryColor}</primaryColor>
            <secondaryColor>${gamelistSecondaryColor}</secondaryColor>
            <fontPath>${fontSemiBold}</fontPath>
            <alignment>left</alignment>
            <pos>0.025 0.2</pos>
            <size>0.319 0.72</size>
            <fontSize>0.03</fontSize>
            <!-- Reduced from 1.683 → 1.4 to show more items on 480px screen -->
            <lineSpacing>1.4</lineSpacing>
            <horizontalMargin>0.01</horizontalMargin>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </textlist>

        <helpsystem name="help">
            <textColor>${helpTextColor}</textColor>
            <iconColor>${helpIconColor}</iconColor>
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.0225</fontSize>
            <pos>0.025 0.975</pos>
            <origin>0 1</origin>
            <iconUpDown>./_art/assets/help-dpad-updown.svg</iconUpDown>
            <iconLeftRight>./_art/assets/help-dpad-leftright.svg</iconLeftRight>
            <iconUpDownLeftRight>./_art/assets/help-dpad-updownleftright.svg</iconUpDownLeftRight>
            <iconA>./_art/assets/help-button-east.svg</iconA>
            <iconB>./_art/assets/help-button-south.svg</iconB>
            <iconX>./_art/assets/help-button-north.svg</iconX>
            <iconY>./_art/assets/help-button-west.svg</iconY>
        </helpsystem>
        <!-- Console Name -->


        <text name="nameLabel" extra="true">
            <fontPath>${fontBold}</fontPath>
            <forceUppercase>1</forceUppercase>
            <color>${gameMetadataLabel}</color>
            <fontSize>0.04</fontSize>
            <alignment>left</alignment>
            <pos>0.025 0.1</pos>
            <size>0.33 0.08</size>
            <zIndex>32</zIndex>
        </text>

        <text name="md_description">
            <fontPath>${fontBold}</fontPath>
            <color>${gameDescription}</color>
            <fontSize>0.03</fontSize>
            <alignment>left</alignment>
            <forceUppercase>0</forceUppercase>
            <lineSpacing>1.18</lineSpacing>
            <origin>0 0</origin>
            <pos>0.4 0.65</pos>
            <size>0.55 0.185</size>
            <container>true</container>
            <verticalAlignment>top</verticalAlignment>
            <zIndex>5</zIndex>
            <autoScroll>vertical</autoScroll>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>

        <!-- Define metadata -->

        <!-- Place metadata -->

        <!-- Extra Text Labels. Edit text values if needed.-->

        <text name="txt_descript" extra="true">
            <text></text>
            <fontPath>${fontBold}</fontPath>
            <alignment>left</alignment>
            <fontSize>0.025</fontSize>
            <color>${gameMetadata}</color>
            <origin>0 0</origin>
            <pos>0.339 0.630</pos>
            <size>0.06 0.2</size>
        </text>

        <!-- Hidden Elements -->

        <text name="shortdescription, longdescription" extra="true">
            <pos>1 1</pos>
            <size>0 0</size>
            <color>00000000</color>
        </text>

        <text
            name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_developer, md_lbl_publisher, md_publisher, md_lbl_genre, md_genre, md_lbl_players, md_players, md_lbl_playcount, md_playcount, md_lbl_lastplayed, md_publsher">
            <color>00000000</color>
            <pos>1 1</pos>
            <size>0 0</size>
        </text>

        <datetime name="md_releasedate, md_lastplayed">
            <color>00000000</color>
            <pos>1 1</pos>
            <size>0 0</size>
        </datetime>
        
        <rating name="md_rating">
            <pos>1 1</pos>
            <size>0 0</size>
        </rating>

    </view>

    <view name="basic, detailed">
        <image name="md_image">
            <tile>false</tile>
            <origin>0 0</origin>
            <pos>0.4 0.125</pos>
            <maxSize>0.55 0.5</maxSize>
            <zIndex>32</zIndex>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </image>
        <image name="md_marquee">
            <origin>0 0</origin>
            <pos>0.75 0.095</pos>
            <maxSize>0.2 0.2</maxSize>
            <zIndex>32</zIndex>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </image>
        <text name="logoText">
            <color>00000000</color>
        </text>

    </view>

    <feature supported="video">
        <view name="video">
            <image name="tvoverlay" extra="true">
                <tile>false</tile>
                <path>${spacerImage}</path>
                <size>1 1</size>
                <pos>1 1</pos>
                <zIndex>31</zIndex>
            </image>
            <image name="md_marquee">
                <origin>0 0</origin>
                <pos>0.75 0.095</pos>
                <maxSize>0.2 0.2</maxSize>
                <zIndex>32</zIndex>
            </image>
            <rating name="md_rating">
                <origin>0 0</origin>
                <pos>0.4 0.85</pos>
                <size>0.05 0.05</size>
                <zIndex>33</zIndex>
                <filledPath>./_art/assets/icon-star-filled.svg</filledPath>
                <!-- Fixed: typo iocn → icon -->
                <unfilledPath>./_art/assets/icon-star-unfilled.svg</unfilledPath>
                <color>${gameMetadata}</color>
            </rating>
            <video name="md_video">
                <origin>0 0</origin>
                <pos>0.4 0.125</pos>
                <maxSize>0.55 0.5</maxSize>
                <delay>1.4</delay>
                <showSnapshotNoVideo>true</showSnapshotNoVideo>
                <showSnapshotDelay>true</showSnapshotDelay>
                <storyboard event="activate">
                    <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
                </storyboard>
            </video>
            <text name="logoText">
                <color>00000000</color>
            </text>
        </view>
    </feature>

    <view name="grid">
        <image name="background" extra="true">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${systemBackgroundColor}</color>
            <zIndex>0</zIndex>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </image>
        <image name="backgroundhelp" extra="true">
            <origin>0 1</origin>
            <pos>0 1</pos>
            <size>1 0.075</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <color>${helpBackgroundColor}</color>
            <zIndex>0</zIndex>
        </image>
        <helpsystem name="help">
            <textColor>${helpTextColor}</textColor>
            <iconColor>${helpIconColor}</iconColor>
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.0225</fontSize>
            <pos>0.025 0.975</pos>
            <origin>0 1</origin>
            <iconUpDown>./_art/assets/help-dpad-updown.svg</iconUpDown>
            <iconLeftRight>./_art/assets/help-dpad-leftright.svg</iconLeftRight>
            <iconUpDownLeftRight>./_art/assets/help-dpad-updownleftright.svg</iconUpDownLeftRight>
            <iconA>./_art/assets/help-button-east.svg</iconA>
            <iconB>./_art/assets/help-button-south.svg</iconB>
            <iconX>./_art/assets/help-button-north.svg</iconX>
            <iconY>./_art/assets/help-button-west.svg</iconY>
        </helpsystem>
        <text name="nameLabel" extra="true">
            <fontPath>${fontBold}</fontPath>
            <forceUppercase>1</forceUppercase>
            <color>${gameMetadataLabel}</color>
            <fontSize>0.04</fontSize>
            <alignment>left</alignment>
            <pos>0.025 0.1</pos>
            <size>0.95 0.08</size>
            <zIndex>32</zIndex>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </text>
        <imagegrid name="gamegrid">
            <pos>0.025 0.19</pos>
            <size>0.95 0.71</size>
            <padding>0.02 0.02</padding>
            <margin>0.015 0.015</margin>
            <autoLayout>4 3</autoLayout>
            <autoLayoutSelectedZoom>1.10</autoLayoutSelectedZoom>
            <animate>true</animate>
            <scrollDirection>vertical</scrollDirection>
            <storyboard event="activate">
                <animation property="opacity" from="0" to="1" duration="400" mode="easeOut" />
            </storyboard>
        </imagegrid>
        <gridtile name="default">
            <padding>4 4</padding>
            <backgroundColor>00000033</backgroundColor>
        </gridtile>
        <gridtile name="selected">
            <padding>4 4</padding>
            <backgroundPath>./_art/assets/grid-border.svg</backgroundPath>
        </gridtile>
        <text name="gridtile.name">
            <color>${gamelistPrimaryColor}</color>
            <fontSize>0.035</fontSize>
            <singleLineScroll>true</singleLineScroll>
        </text>
    </view>

    <view name="screen">
        <text name="clock">
            <color>${batteryIndicatorColor}</color>
            <fontSize>0.035</fontSize>
            <fontPath>${menuFontBold}</fontPath>
            <pos>0.025 0.01</pos>
            <size>0.5 0.058</size>
            <alignment>left</alignment>
            <verticalAlignment>center</verticalAlignment>
        </text>
        <!-- Battery indicator: icon paths fixed (./_art/), size matches clock height,
             duplicate tinyScreen block removed (unsupported attribute) -->
        <batteryIndicator name="batteryIndicator">
            <pos>0.845 0.003</pos>
            <!-- size 0.055 gives icon height ~26px, matching clock text at fontSize 0.035 -->
            <size>0.055 0.055</size>
            <incharge>./_art/battery/incharge.svg</incharge>
            <full>./_art/battery/full.svg</full>
            <at75>./_art/battery/75.svg</at75>
            <at50>./_art/battery/50.svg</at50>
            <at25>./_art/battery/25.svg</at25>
            <empty>./_art/battery/empty.svg</empty>
            <color>${batteryIndicatorColor}</color>
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.035</fontSize>
        </batteryIndicator>
    </view>

    <view name="menu">
        <menuText name="menutitle">
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.038</fontSize>
            <color>ffffff</color>
        </menuText>
        <menuText name="menufooter">
            <fontPath>${menuFontLight}</fontPath>
            <fontSize>0.028</fontSize>
            <color>ffffff77</color>
        </menuText>
        <menuText name="menutext">
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.038</fontSize>
            <color>ffffff77</color>
            <separatorColor>ffffff11</separatorColor>
            <selectedColor>ffffff</selectedColor>
        </menuText>
        <menuTextSmall name="menutextsmall">
            <fontPath>${menuFontBold}</fontPath>
            <fontSize>0.028</fontSize>
            <color>ffffff77</color>
        </menuTextSmall>
        <menuGroup name="menugroup">
            <fontPath>${menuFontRegular}</fontPath>
            <fontSize>0.0325</fontSize>
            <color>ffffff</color>
            <separatorColor>ffffff99</separatorColor>
            <backgroundColor>00000000</backgroundColor>
            <lineSpacing>2.5</lineSpacing>
        </menuGroup>
        <menuBackground name="menubg">
            <color>111111</color>
            <cornerSize>20 20</cornerSize>
        </menuBackground>
        <menuIcons name="menuicons">
            <iconSystem>./_art/assets/menu-icon-system.svg</iconSystem>
            <iconUpdates>./_art/assets/menu-icon-update.svg</iconUpdates>
            <iconBrightnessctl>./_art/assets/menu-icon-display.svg</iconBrightnessctl>
            <iconControllers>./_art/assets/menu-icon-controller.svg</iconControllers>
            <iconGames>./_art/assets/menu-icon-games.svg</iconGames>
            <iconUI>./_art/assets/menu-icon-ui.svg</iconUI>
            <iconSound>./_art/assets/menu-icon-sound.svg</iconSound>
            <iconNetwork>./_art/assets/menu-icon-network.svg</iconNetwork>
            <iconScraper>./_art/assets/menu-icon-scraper.svg</iconScraper>
            <iconOptions>./_art/assets/menu-icon-options.svg</iconOptions>
            <iconAdvanced>./_art/assets/menu-icon-advanced.svg</iconAdvanced>
            <iconQuit>./_art/assets/menu-icon-quit.svg</iconQuit>
            <iconRetroachievements>./_art/assets/menu-icon-achievements.svg</iconRetroachievements>
            <iconKodi>./_art/assets/menu-icon-kodi.svg</iconKodi>
            <iconRestart>./_art/assets/menu-icon-restart.svg</iconRestart>
            <iconShutdown>./_art/assets/menu-icon-shutdown.svg</iconShutdown>
            <iconFastShutdown>./_art/assets/menu-icon-shutdown.svg</iconFastShutdown>
        </menuIcons>
        <menuTextEdit name="menutextedit">
            <inactive>./_art/assets/menu-textinput.png</inactive>
            <active>./_art/assets/menu-textinput-active.png</active>
        </menuTextEdit>
    </view>
</theme>